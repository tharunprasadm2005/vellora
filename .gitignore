# Environment files (CRITICAL)
# =====================
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.test

# Backend secrets (IMPORTANT ADDITION)
config.env
secrets.env

# =====================
# Logs
# =====================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =====================
# OS files
# =====================
.DS_Store
Thumbs.db

# =====================
# Editors / IDEs
# =====================
.vscode/
.idea/

# =====================
# Coverage / Cache
# =====================
coverage/
.cache/
.parcel-cache/

